# ─── AWS Credentials ──────────────────────────────────────────────────────────
# Create an IAM user with: Bedrock, Polly, S3, DynamoDB permissions
# Get keys from: AWS Console → IAM → Users → Security credentials
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_DEFAULT_REGION=ap-south-1

# ─── Amazon Bedrock ───────────────────────────────────────────────────────────
# Claude 3 Sonnet (recommended) — make sure Bedrock model access is enabled in ap-south-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ─── Amazon S3 ────────────────────────────────────────────────────────────────
# Create an S3 bucket in ap-south-1 for audio file storage
S3_BUCKET_NAME=bharat-samachar-audio

# ─── Amazon DynamoDB ──────────────────────────────────────────────────────────
# Table is auto-created on first run via POST /api/setup
DYNAMO_TABLE_NAME=bharat-samachar-articles

# ─── Application ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
AUDIO_PRESIGNED_URL_EXPIRY=3600
